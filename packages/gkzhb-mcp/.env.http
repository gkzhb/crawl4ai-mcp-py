# MCP server configuration
MCP_TYPE=http
MCP_TOOL_LIST=crawl4ai,searxng
MCP_HOST=127.0.0.1
MCP_PORT=8003

# Environment: development | production
ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# SearXNG configuration
SEARXNG_URL=https://searchxxx

# supports browserless ws endpoint or chrome cdp http endpoint
# CHROME_CDP_ENDPOINT=ws://localhost:3000?token=xxx

